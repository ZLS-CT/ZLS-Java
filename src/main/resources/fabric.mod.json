{
    "schemaVersion": 1,
    "id": "zls",
    "version": "${version}",
    "name": "ZLS",
    "description": "Scanner for valuable items on Hypixel SkyBlock. Includes Exotics, Crystal, Fairy, OG Fairy, Glitched, Seymour, and much more!",
    "authors": [
        "Zephy"
    ],
    "contact": {
        "sources": "https://github.com/ZLS-CT/ZLS-Java",
        "issues": "https://github.com/ZLS-CT/ZLS-Java/issues"
    },
    "environment": "client",
    "entrypoints": {
        "preLaunch": [
            "com.zephy.zls.PreLaunch"
        ]
    },
    "mixins": [
        "zls.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.18.0",
        "fabric-api": ">=$min_fabric_api_version",
        "fabric-language-kotlin": ">=1.13.8+kotlin.2.3.0",
        "zjs": ">=1.0.0"
    }
}
